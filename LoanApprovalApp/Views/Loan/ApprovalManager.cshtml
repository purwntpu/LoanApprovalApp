<table class="table table-bordered">
    <thead>
        <tr>
            <th>No</th>
            <th>Request Number</th>
            <th>Amount</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.RequestNumber</td>
                <td>@item.Amount</td>
                <td>@item.Status</td>
                <td>
                    @if (item.Status == "Pending")
                    {
                        <a asp-action="ApproveManager" asp-route-id="@item.Id" class="btn btn-success btn-sm">Approve</a>
                        <a asp-action="RejectManager" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Reject</a>
                    }
                    else
                    {
                        <span class="text-muted">No actions</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
